# ─── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://saas_user:saas_password_dev@localhost:5432/saas_platform?schema=public"

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT Secrets ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-this-to-a-random-64-byte-hex-string-for-production"
JWT_REFRESH_SECRET="change-this-to-another-random-64-byte-hex-string-for-production"

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── App URLs ────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# ─── Email ───────────────────────────────────────────────────────
EMAIL_FROM="noreply@saas-platform.dev"
EMAIL_PROVIDER="console"
# RESEND_API_KEY=""

# ─── Frontend (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
